{
  "name": "android-mem-profiler",
  "version": "0.1.0",
  "description": "实时安卓系统内存抓取分析工具（Electron + TypeScript）",
  "main": "./out/main/index.js",
  "author": "72190609",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "antd": "^6.5.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.2",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "jimp": "^1.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.6",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.vivo.android-mem-profiler",
    "productName": "AndroidMemProfiler",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "afterPack": "scripts/afterPack.js",
    "files": [
      "out/**/*",
      "build/icon.png",
      "node_modules/**/*",
      "!node_modules/exceljs/dist/**/*.map",
      "!node_modules/exceljs/dist/es5",
      "!node_modules/exceljs/dist/exceljs.js",
      "!node_modules/exceljs/dist/exceljs.bare.js",
      "!node_modules/exceljs/dist/exceljs.min.js.map",
      "!node_modules/exceljs/dist/exceljs.bare.min.js.map",
      "!node_modules/exceljs/README_zh.md"
    ],
    "asar": true,
    "asarUnpack": [
      "out/main/poller-worker.js",
      "out/main/chunks/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "compression": "maximum"
  }
}
