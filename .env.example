# 调试模式（启用后日志写入 logs/ttyd-debug.log）
DEBUG=false

# 认证调试模式（true 跳过飞书 OAuth 认证，使用默认调试用户）
AUTH_DEBUG=false

# 服务器配置
PORT=3000
HTTPS=true
FRONTEND_URL=https://localhost:5173

# 飞书 OAuth 配置
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_REDIRECT_URI=https://localhost:3000/auth/feishu/callback

# ADB 配置（可选，优先使用项目内置 bin/platform-tools/adb.exe）
# ADB_PATH=adb

# ttyd 终端配置
TTYD_PORT_START=7681
TTYD_PORT_END=7690
TTYD_CREDENTIAL=admin:admin

# 数据库配置（PostgreSQL）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tscameratools
DB_PASSWORD=postgres

# 会话配置
SESSION_EXPIRY_HOURS=24
