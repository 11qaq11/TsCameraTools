{
  "name": "ts-camera-tools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsx watch server/index.ts\" \"wait-on http://localhost:5173 http://localhost:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "tsc -b && vite build && electron-builder --win",
    "electron:pack": "tsc -b && vite build && electron-builder --win --dir",
    "server:dev": "tsx watch server/index.ts",
    "server:build": "tsc -p tsconfig.server.json",
    "server:start": "node dist/server/index.js",
    "web:dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "web:build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "web:start": "node dist/server/index.js",
    "test": "vitest run",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:all": "vitest run && vitest run --config vitest.server.config.ts",
    "test:coverage": "vitest run --coverage && vitest run --config vitest.server.config.ts --coverage"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/socket.io-client": "^1.4.36",
    "@types/uuid": "^10.0.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "exceljs": "^4.4.0",
    "express": "^4.22.2",
    "lucide-react": "^1.23.0",
    "node-pty": "^1.1.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "redux": "^5.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.23.0",
    "uuid": "^9.0.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "@types/pino-http": "^5.8.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.thundersoft.tscameratools",
    "productName": "TsCameraTools",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "TsCameraTools"
    }
  }
}
